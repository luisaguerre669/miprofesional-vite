# ==============================
# MiProfesional - Production ENV
# ==============================
NODE_ENV=production
PORT=10000

# MongoDB Atlas (production)
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/miprofesional?retryWrites=true&w=majority

# JWT
JWT_SECRET=<generate-a-long-random-64-char-string>
JWT_REFRESH_SECRET=<generate-another-long-random-64-char-string>
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGIN=https://miprofesional.com
FRONTEND_URL=https://miprofesional.com

# Google OAuth (optional - for social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.miprofesional.com/auth/google/callback

# MercadoPago (optional - for subscriptions)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# MongoDB options
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=5000
