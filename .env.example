# --- Servidor ---
NODE_ENV=development
PORT=10000

# --- MongoDB ---
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/miprofesional?retryWrites=true&w=majority

# --- JWT ---
JWT_SECRET=generate-a-random-64-char-secret-here
JWT_REFRESH_SECRET=generate-another-random-64-char-secret-here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# --- Bcrypt ---
BCRYPT_ROUNDS=12

# --- CORS ---
CORS_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# --- MercadoPago ---
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxx
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret
MERCADOPAGO_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# --- Upload ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# --- MongoDB Timeouts ---
MONGO_SERVER_SELECTION_TIMEOUT_MS=15000
MONGO_CONNECT_TIMEOUT_MS=15000
