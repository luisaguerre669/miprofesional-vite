# --- Servidor ---
NODE_ENV=development
PORT=10000

# --- MongoDB --- (necesitas cambiar esto por tu URI real de Atlas o local)
MONGODB_URI=mongodb://localhost:27017/miprofesional

# --- JWT ---
JWT_SECRET=miprofesional-dev-jwt-secret-key-64-chars-minimum-for-hs256-algorithm
JWT_REFRESH_SECRET=miprofesional-dev-refresh-secret-key-also-64-chars-minimum-for-safety
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# --- Bcrypt ---
BCRYPT_ROUNDS=12

# --- CORS ---
CORS_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# --- MercadoPago ---
MERCADOPAGO_ACCESS_TOKEN=TEST-0000000000000000-000000-00000000000000000000000000000000-000000000
MERCADOPAGO_WEBHOOK_SECRET=test-webhook-secret
MERCADOPAGO_PUBLIC_KEY=TEST-00000000-0000-0000-0000-000000000000

# --- MongoDB Timeouts ---
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=5000
